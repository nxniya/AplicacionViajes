<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/teal_50">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/teal_800"
            android:padding="20dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filtrar Viajes"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ajusta los criterios de búsqueda"
                android:textSize="13sp"
                android:textColor="@color/teal_300" />

        </LinearLayout>

        <!-- Filter content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CIUDAD"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/teal_700"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etCityFilter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ej. Madrid"
                android:backgroundTint="@color/teal_300"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RANGO DE PRECIO"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/teal_700"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.slider.RangeSlider
                android:id="@+id/priceRangeSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0.0"
                android:valueTo="2000.0"
                app:values="@array/initial_range_values"
                app:trackColorActive="@color/teal_500"
                app:trackColorInactive="@color/teal_100"
                app:thumbColor="@color/teal_700"
                app:haloColor="@color/teal_100" />

            <TextView
                android:id="@+id/tvPriceRange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="0€ - 2000€"
                android:textColor="@color/teal_700"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RANGO DE FECHAS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/teal_700"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btnMinDate"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Desde"
                    app:strokeColor="@color/teal_300" />

                <Button
                    android:id="@+id/btnMaxDate"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Hasta"
                    app:strokeColor="@color/teal_300" />

            </LinearLayout>

            <CheckBox
                android:id="@+id/cbSoloFavoritos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:text="Solo favoritos"
                android:textColor="@color/teal_900"
                android:buttonTint="@color/purple_500" />

            <Button
                android:id="@+id/btnApplyFilter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aplicar Filtros"
                app:backgroundTint="@color/teal_700"
                android:textColor="@color/white" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
